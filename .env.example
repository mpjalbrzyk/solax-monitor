# Solax Monitor — Environment Variables Template
# Skopiuj ten plik do .env.local (gitignored) i wypełnij realnymi wartościami.
# NIGDY nie commituj .env.local do git.

# ============================================================
# Solax Developer Portal API
# ============================================================
# Z developer.solaxcloud.com > Application > Solax Monitor > Authorization
SOLAX_CLIENT_ID=
SOLAX_CLIENT_SECRET=
SOLAX_BASE_URL=https://openapi-eu.solaxcloud.com
# Hardcoded dla MVP, multi-tenant w produkcji ciągnie z user_inverters
SOLAX_PLANT_ID=1613529907775754244
SOLAX_INVERTER_SN=H34B10H7319017
SOLAX_DONGLE_SN=SXTGG4YRYR

# ============================================================
# Supabase
# ============================================================
# Z supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role TYLKO dla server-side i n8n, NIGDY w client bundle
SUPABASE_SERVICE_ROLE_KEY=
# Database URL dla migracji
SUPABASE_DB_URL=

# ============================================================
# Anthropic Claude API
# ============================================================
# Z console.anthropic.com > API Keys
ANTHROPIC_API_KEY=
# Modele używane (zgodnie z 03-decisions.md D-001)
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ============================================================
# Voyage AI (embeddings dla RAG)
# ============================================================
# Z voyageai.com > API Keys
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_EMBEDDING_DIMENSIONS=1024

# ============================================================
# Resend (email)
# ============================================================
# Z resend.com > API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=solar@mpjalbrzyk.pl
RESEND_REPLY_TO=mpjalbrzyk@gmail.com

# ============================================================
# Healthchecks.io (cron monitoring)
# ============================================================
# Po jednym ping URL per workflow
HEALTHCHECK_TOKEN_REFRESH=
HEALTHCHECK_POLLING_REALTIME=
HEALTHCHECK_POLLING_ALARMS=
HEALTHCHECK_DAILY_AGGREGATES=
HEALTHCHECK_WEEKLY_DIGEST=

# ============================================================
# n8n (jeśli aplikacja webhookuje do n8n)
# ============================================================
N8N_BASE_URL=https://n8n.solar.mpjalbrzyk.pl
N8N_WEBHOOK_TOKEN=

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_URL=https://solar.mpjalbrzyk.pl
NEXT_PUBLIC_APP_NAME=Solax Monitor
# Dla onboarding flow
DEFAULT_USER_TIMEZONE=Europe/Warsaw

# ============================================================
# Sentry (error tracking, opcjonalnie)
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=solax-monitor

# ============================================================
# Development only
# ============================================================
NODE_ENV=development
LOG_LEVEL=debug
